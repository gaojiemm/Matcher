{
	"version": "0.2",
	"problemMatcher": [
		{
			"owner": "test-failure",
			"source": "test",
			"applyTo": "allDocuments",
			"fileLocation": ["relative"],
			"pattern": [
				{
					"regexp": "^(.*):(\\d+):(\\d+)\\s+(.*)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"message": 4
				}
			]
		}
	]
}